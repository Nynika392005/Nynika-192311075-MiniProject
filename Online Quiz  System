import java.util.*;

class Question {
    String question;
    String[] options;
    int correctAnswer;

    Question(String question, String[] options, int correctAnswer) {
        this.question = question;
        this.options = options;
        this.correctAnswer = correctAnswer;
    }

    void display() {
        System.out.println(question);
        for (int i = 0; i < options.length; i++) {
            System.out.println((i + 1) + ". " + options[i]);
        }
    }
}

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        ArrayList<Question> quiz = new ArrayList<>();

        quiz.add(new Question("What is Java?",
                new String[]{"Programming Language", "Car", "Animal", "Food"}, 1));

        quiz.add(new Question("Which keyword is used for inheritance?",
                new String[]{"this", "super", "extends", "implements"}, 3));

        quiz.add(new Question("Which method is entry point of Java?",
                new String[]{"start()", "run()", "main()", "init()"}, 3));

        int score = 0;

        System.out.println("--- Online Quiz ---");

        for (Question q : quiz) {
            q.display();
            System.out.print("Enter your answer: ");
            int ans = sc.nextInt();

            if (ans == q.correctAnswer) {
                System.out.println("Correct!\n");
                score++;
            } else {
                System.out.println("Wrong!\n");
            }
        }

        System.out.println("Your Score: " + score + "/" + quiz.size());

        sc.close();
    }
}
